        "lineageTag": "49b77d3a-9f08-4b52-9aae-256ca258ab42",
        "measures": [
          {
            "name": "Qtd. Filmes",
            "displayFolder": "QTD. Filmes",
            "expression": "COUNT('imdb_movies'[id])",
            "formatString": "0",
            "lineageTag": "b69b1357-b995-4dd8-845a-fab23753d922"
          },
          {
            "name": "Arrecadação World_Wide",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Arrecadação",
            "expression": "SUM('imdb_movies'[gross_world_wide])",
            "lineageTag": "309cd5ff-4ff4-4e21-b4d7-2aaa4580d8ce"
          },
          {
            "name": "Budget",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Lucro/Perda",
            "expression": "SUM('imdb_movies'[budget])",
            "lineageTag": "6b0d9acb-7cbc-47ca-b50a-c445ea9bf036"
          },
          {
            "name": "Arrecadação EUA",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Arrecadação",
            "expression": "SUM('imdb_movies'[gross_us_canada])",
            "lineageTag": "7b348618-dac9-4ede-a4cb-c59e51672234"
          },
          {
            "name": "Performance (Filmes geração Z)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Performance em Avaliação",
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGE('imdb_movies'[rating_imdb]),",
              "    imdb_movies[year] >= 2000",
              ")"
            ],
            "lineageTag": "914911b4-899d-4aa5-a959-7f27281e5066"
          },
          {
            "name": "Desempenho",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Lucro/Perda",
            "expression": "[Arrecadação World_Wide]-[Budget]",
            "lineageTag": "3fde7277-fb4b-43f2-84a1-c533758ecdd5"
          },
          {
            "name": "Nomiações",
            "displayFolder": "Performance em Avaliação",
            "expression": "SUM(imdb_movies[nomination])",
            "formatString": "0",
            "lineageTag": "c80ddc4d-43da-4860-bcff-48eeaa090480"
          },
          {
            "name": "Ticket Médio (Arrecadação)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"es-US\"}"
              }
            ],
            "expression": [
              "",
              "VAR vArrecadacaoTotal = SUM('imdb_movies'[gross_world_wide])",
              "VAR vQtdFilmesComDados = ",
              "    COUNTROWS(",
              "        FILTER(",
              "            imdb_movies, ",
              "            NOT(ISBLANK('imdb_movies'[gross_world_wide]))",
              "        )",
              "    )",
              "",
              "RETURN",
              "DIVIDE(vArrecadacaoTotal, vQtdFilmesComDados, 0)"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "lineageTag": "1050db64-76de-4010-859e-18d663177ed1"
          },
          {
            "name": "Ticket Médio Formatado",
            "expression": [
              "",
              "VAR vTicket = [Ticket Médio (Arrecadação)]",
              "RETURN",
              "\"U$ \" & FORMAT(vTicket, \"#,##0\")"
            ],
            "lineageTag": "c96067a7-41e3-415d-9ac4-4555affa3e35"
          }
        ],
