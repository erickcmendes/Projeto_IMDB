                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "IF(",
              "    ISBLANK('imdb_movies'[filming_location]), ",
              "    \"Desconhecido\", ",
              "    'imdb_movies'[filming_location]",
              ")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "e1cb716a-a4ed-454f-94c1-0c0a79a78ca5",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Status de Crítica",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "IF(",
              "    'imdb_movies'[rating_imdb] >= 80, ",
              "    \"Excelente\", ",
              "    \"Comum\"",
              ")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "f74bd9bc-67dd-4ab5-8dbb-2013781d817a",
            "summarizeBy": "none",
            "type": "calculated"
          }
